{
  "name": "Стол и Кабинет",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "postCreateCommand": "npm install",
  "postAttachCommand": "npm run dev",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Приложение (Стол и Кабинет)",
      "onAutoForward": "openBrowserOnce"
    }
  }
}
